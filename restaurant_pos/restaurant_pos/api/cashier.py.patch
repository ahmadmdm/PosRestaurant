+def create_pos_invoice_for_order(order, payment_data):
+    """Create an ERPNext POS Invoice from Restaurant Order"""
+    if not frappe.db.exists("DocType", "POS Invoice"):
+        return None
+        
+    # Determine POS Profile
+    pos_profile = frappe.db.get_value("POS Profile", {"user": frappe.session.user, "company": frappe.defaults.get_user_default("company")})
+    if not pos_profile:
+        pos_profile = frappe.db.get_value("POS Profile", {"company": frappe.defaults.get_user_default("company")})
+        
+    if not pos_profile:
+        frappe.throw(_("No POS Profile found for user or company. Please configure POS Profile."))
+        
+    profile_doc = frappe.get_cached_doc("POS Profile", pos_profile)
+    
+    # Prepare POS Invoice Doc
+    pi = frappe.new_doc("POS Invoice")
+    pi.is_pos = 1
+    pi.pos_profile = pos_profile
+    pi.company = profile_doc.company
+    pi.customer = order.customer or profile_doc.customer or frappe.db.get_value("Customer", {"customer_group": "Commercial", "disabled": 0})
+    pi.set_posting_time = 1
+    pi.posting_date = frappe.utils.nowdate()
+    pi.posting_time = frappe.utils.nowtime()
+    
+    for item in order.items:
+        menu_item = frappe.db.get_value("Menu Item", item.menu_item, ["linked_item", "item_name"], as_dict=True)
+        item_code = menu_item.linked_item if menu_item and menu_item.linked_item else menu_item.item_name
+        
+        # Fallback if linked item is missing but exact name exists in ERPNext Items
+        if not frappe.db.exists("Item", item_code):
+            continue # Skip or handle properly based on real DB integration
+            
+        pi.append("items", {
+            "item_code": item_code,
+            "qty": item.qty,
+            "rate": item.rate,
+            "warehouse": profile_doc.warehouse,
+            "income_account": profile_doc.income_account
+        })
+        
+    if not pi.items:
+        frappe.throw(_("No valid ERPNext items found in the order to create a valid POS Invoice"))
+        
+    pi.append("payments", {
+        "mode_of_payment": payment_data.get("method", "Cash"),
+        "amount": flt(payment_data.get("amount", order.grand_total))
+    })
+    
+    pi.insert()
+    pi.submit()
+    return pi.name
 
